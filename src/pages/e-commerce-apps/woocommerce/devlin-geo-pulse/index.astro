---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const plugin = {
  name: "Devlin Geo Pulse",
  slug: "devlin-geo-pulse",
  version: "1.0.3",
  testedWP: "6.8.x",
  testedWC: "10.x",
  minPHP: "8.2",
  minWP: "6.4",
  minWC: "8.0",
  license: "GPL-2.0-or-later",
  wpOrgUrl: "https://wordpress.org/plugins/devlin-geo-pulse/",
  githubUrl: "https://github.com/devlinduldulao/devlin-geo-pulse",
  authorUrl: "https://devlinduldulao.pro",
  tagline: "See who's shopping — live, private, and lightweight.",
  description:
    "A lightweight WooCommerce plugin that shows real-time visitor presence on your store dashboard. Know how many shoppers are active right now, where they're from, and what devices they're using — without storing a single IP address.",
};

const features = [
  {
    icon: "🌍",
    title: "Live Country Breakdown",
    desc: "See active visitors ranked by country. A visual meter makes traffic concentration immediately obvious at a glance.",
  },
  {
    icon: "📱",
    title: "Device Mix Panel",
    desc: "Track the split between desktop, mobile, tablet, and bot traffic in real time, updated on every heartbeat.",
  },
  {
    icon: "💓",
    title: "Heartbeat Presence",
    desc: "Visitors send a lightweight ping on a configurable interval. When pings stop, presence expires automatically — no stale data.",
  },
  {
    icon: "🔒",
    title: "Zero IP Storage",
    desc: "Country is resolved at request time and immediately discarded. No raw IPs are logged, cached, or persisted anywhere.",
  },
  {
    icon: "⚡",
    title: "WooCommerce Native",
    desc: "Lives entirely inside WooCommerce — a submenu dashboard page and a settings tab. No new admin menus cluttering your sidebar.",
  },
  {
    icon: "🧪",
    title: "Preview Traffic Mode",
    desc: "On dev and staging environments, inject sample visitors to preview the dashboard layout without real traffic.",
  },
];

const steps = [
  { step: "01", title: "Visitor loads your store", desc: "The frontend script starts a heartbeat timer as soon as any WooCommerce page is viewed." },
  { step: "02", title: "Heartbeat fires", desc: "A lightweight JSON request hits the REST API with no personal data — just a hashed session token and device hint." },
  { step: "03", title: "Country is resolved", desc: "The server resolves the country from the request in memory and increments an object cache counter. The IP is never written anywhere." },
  { step: "04", title: "Dashboard updates", desc: "Your WooCommerce admin dashboard polls the same REST API and re-renders the live stats table and device panel in place." },
  { step: "05", title: "Presence expires", desc: "When a visitor's heartbeats stop, their slot expires automatically based on the configured TTL. No cleanup jobs needed." },
];

const privacyPoints = [
  "No IP addresses are stored, logged, or transmitted to third parties.",
  "Only coarse country-level presence is tracked — never city or coordinates.",
  "No persistent visitor history: all data lives in object cache with a short TTL.",
  "No cookies are set by the plugin.",
  "No personal data is collected under GDPR Article 4(1).",
  "Compatible with standard WordPress privacy tools and GDPR plugins.",
];
---

<Layout title={`${plugin.name} — Live Visitor Geo Tracking for WooCommerce`}>
  <Header />
  <main id="main-content">

    <!-- Hero -->
    <section class="border-skin-line border-b">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span class="bg-skin-accent text-skin-inverted rounded px-2 py-0.5 text-xs font-semibold">
            v{plugin.version}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            WP {plugin.minWP}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            WC {plugin.minWC}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            PHP {plugin.minPHP}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            {plugin.license}
          </span>
        </div>

        <h1 class="mb-4 text-4xl font-bold leading-tight">
          {plugin.name}
        </h1>
        <p class="text-skin-base mb-3 text-xl font-medium opacity-90">
          {plugin.tagline}
        </p>
        <p class="text-skin-base mb-8 max-w-2xl text-base leading-relaxed opacity-70">
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.wpOrgUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition hover:brightness-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1.086 14.432L7.11 10.19h1.814l2.03 5.034 2.03-5.034h1.814l-3.884 6.242zM17.5 10.19h-1.726v5.44H14.06V10.19h-1.016V8.906H14.06V8.12c0-1.358.56-2.165 2.155-2.165h1.285v1.284h-.803c-.602 0-.641.224-.641.643v1.024H17.5v1.284z"/>
            </svg>
            Download on WordPress.org
          </a>
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="text-skin-base mb-8 opacity-60">Everything you need. Nothing you don't.</p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="border-skin-line bg-skin-card rounded-lg border p-5 shadow-sm transition hover:shadow-md">
            <div class="mb-3 text-3xl">{f.icon}</div>
            <h3 class="mb-1.5 text-base font-semibold">{f.title}</h3>
            <p class="text-sm leading-relaxed opacity-65">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="text-skin-base mb-10 opacity-60">Five steps from page load to live dashboard.</p>
        <ol class="space-y-0">
          {steps.map((s, i) => (
            <li class="flex gap-6">
              <div class="flex flex-col items-center">
                <div class="bg-skin-accent text-skin-inverted flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold">
                  {s.step}
                </div>
                {i < steps.length - 1 && (
                  <div class="border-skin-line my-1 w-px grow border-l border-dashed" />
                )}
              </div>
              <div class="pb-8">
                <h3 class="mb-1 font-semibold">{s.title}</h3>
                <p class="text-sm leading-relaxed opacity-65">{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Privacy -->
    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="border-skin-line bg-skin-card rounded-xl border p-8 shadow-sm">
          <div class="mb-1 text-3xl">🛡️</div>
          <h2 class="mb-2 text-2xl font-bold">Privacy by design</h2>
          <p class="text-skin-base mb-6 opacity-60">
            Built to be GDPR-compatible from the ground up. No consent banners required for this plugin alone.
          </p>
          <ul class="space-y-3">
            {privacyPoints.map((point) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed">
                <svg xmlns="http://www.w3.org/2000/svg" class="text-skin-accent mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="opacity-75">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Requirements & Installation -->
    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">

          <!-- Requirements -->
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-skin-line divide-y">
                {[
                  ["WordPress", `${plugin.minWP} or higher`],
                  ["WooCommerce", `${plugin.minWC} or higher`],
                  ["PHP", `${plugin.minPHP} or higher`],
                  ["Object cache", "Recommended (Memcached / Redis)"],
                  ["Tested up to WP", plugin.testedWP],
                  ["Tested up to WC", plugin.testedWC],
                ].map(([label, value]) => (
                  <tr>
                    <td class="py-2.5 pr-4 font-medium opacity-70">{label}</td>
                    <td class="py-2.5 opacity-90">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <!-- Installation -->
          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {[
                "Download the plugin zip from WordPress.org.",
                "In your WordPress admin, go to Plugins → Add New → Upload Plugin.",
                "Upload the zip and click Install Now, then Activate.",
                "Make sure WooCommerce is active — this plugin requires it.",
                "Visit WooCommerce → Live Geo Pulse to see your live dashboard.",
                "Configure the heartbeat interval under WooCommerce → Settings → Devlin Geo Pulse.",
              ].map((step, i) => (
                <li class="flex gap-3">
                  <span class="border-skin-line text-skin-accent shrink-0 rounded border px-1.5 py-0.5 text-xs font-bold tabular-nums">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="opacity-75 leading-snug">{step}</span>
                </li>
              ))}
            </ol>
          </div>

        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {[
            {
              q: "Does this plugin work without an object cache?",
              a: "Yes, it falls back to WordPress transients. An object cache (Redis or Memcached) is strongly recommended for accurate real-time counts, especially on high-traffic stores.",
            },
            {
              q: "Will it slow down my store?",
              a: "No. The frontend heartbeat is a single lightweight fetch request (< 1 KB payload) fired on a configurable interval (default 45 seconds). It runs completely asynchronously and has no impact on page load.",
            },
            {
              q: "Does it track logged-out visitors?",
              a: "Yes. The heartbeat fires for all visitors — logged in or not — using an anonymous session hash. No personally identifiable information is associated with the hash.",
            },
            {
              q: "Can I disable the privacy notice on the storefront?",
              a: "The plugin does not add any storefront notice by default. A configurable opt-in notice text is available under WooCommerce Settings if you choose to display one.",
            },
            {
              q: "Is the data accurate to the second?",
              a: "Presence is heartbeat-based, so accuracy depends on the interval. At the default 45-second window, counts are accurate to within one interval. You can lower the interval for tighter accuracy at the cost of slightly more server requests.",
            },
          ].map((item) => (
            <details class="border-skin-line bg-skin-card group rounded-lg border shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-semibold text-sm select-none">
                <span>{item.q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 transition-transform group-open:rotate-180 opacity-50" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </summary>
              <p class="border-skin-line border-t px-5 py-4 text-sm leading-relaxed opacity-70">
                {item.a}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14 text-center">
        <h2 class="mb-3 text-2xl font-bold">Ready to see who's shopping?</h2>
        <p class="text-skin-base mb-8 opacity-60">Free, open source, and takes under two minutes to install.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href={plugin.wpOrgUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-6 py-3 text-sm font-semibold transition hover:brightness-110"
          >
            Download Free on WordPress.org
          </a>
          <a
            href="/woocommerce/"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-6 py-3 text-sm font-semibold transition hover:shadow-md"
          >
            ← Back to plugin gallery
          </a>
        </div>
        <p class="mt-6 text-xs opacity-40">
          {plugin.license} &nbsp;·&nbsp; Developed by
          <a href={plugin.authorUrl} class="underline decoration-dashed underline-offset-2 hover:opacity-70" target="_blank" rel="noopener noreferrer">
            Devlin Duldulao
          </a>
        </p>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
