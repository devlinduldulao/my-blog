---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const plugin = {
  name: "Theme Performance Pulse",
  slug: "theme-performance-pulse",
  version: "1.0.1",
  testedOC: "4.1.0.3",
  minPHP: "8.3",
  minOC: "4.x",
  license: "MIT",
  githubUrl: "https://github.com/devlinduldulao/opencart_theme_performance_pulse",
  authorUrl: "https://devlinduldulao.pro",
  tagline: "Short-lived storefront performance monitoring for OpenCart.",
  description:
    "A lightweight OpenCart extension that captures coarse browser performance signals, keeps only a short-lived rolling snapshot in cache, and renders a live admin dashboard for operators — without custom analytics tables, Redis, or Node services.",
};

const features = [
  {
    icon: "📊",
    title: "Live Snapshot Dashboard",
    desc: "View current storefront health in one admin screen with summary cards, degraded-signal counts, incident hints, and recent-event rollups.",
  },
  {
    icon: "⚡",
    title: "Core Web Vitals Summaries",
    desc: "Capture coarse browser-side performance signals so you can spot slow templates, degraded routes, and operational regressions quickly.",
  },
  {
    icon: "🧭",
    title: "OpenCart Native Placement",
    desc: "Built as a normal OpenCart module with a Bootstrap 5 and OpenCart-native admin interface rather than a separate analytics app.",
  },
  {
    icon: "🕒",
    title: "Short-Lived Cache Only",
    desc: "All live data stays in OpenCart cache with a rolling window. No custom analytics tables or long-term history are added to the store.",
  },
  {
    icon: "🔒",
    title: "Privacy-Conscious Tracking",
    desc: "No IP addresses, visitor identifiers, or personal data are stored. The extension is intentionally operational, not behavioral analytics.",
  },
  {
    icon: "🧪",
    title: "Preview Mode",
    desc: "Review the dashboard state safely without altering the live snapshot, making it easier to test UI flows during development or demo sessions.",
  },
];

const steps = [
  { step: "01", title: "Storefront tracker loads", desc: "The extension injects a lightweight tracker on supported storefront routes through OpenCart events." },
  { step: "02", title: "Browser metrics are sampled", desc: "The tracker captures coarse performance signals such as page views, Web Vitals summaries, optional long tasks, and optional add-to-cart delay." },
  { step: "03", title: "Snapshot is updated", desc: "The server validates the request and writes the rolling snapshot into OpenCart cache with expiry and lightweight rate-limiting guards." },
  { step: "04", title: "Admin dashboard refreshes", desc: "The module dashboard polls the current snapshot and re-renders summary cards, breakdown rows, and recent event data in place." },
  { step: "05", title: "Old data expires", desc: "As the rolling window advances, stale metrics fall out automatically. No long-term analytics database or cleanup worker is needed." },
];

const privacyPoints = [
  "No IP addresses are stored in settings, cache, or custom tables.",
  "No visitor identifiers or personal data are collected.",
  "Only coarse operational performance signals are retained.",
  "All snapshot data is short-lived and cache-backed.",
  "No Redis, queue worker, WebSocket service, or Node backend is required.",
  "The extension is designed for operators, not shopper-facing surveillance.",
];
---

<Layout title={`${plugin.name} — Live Storefront Monitoring for OpenCart`}>
  <Header />
  <main id="main-content">
    <section class="border-skin-line border-b">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span class="bg-skin-accent text-skin-inverted rounded px-2 py-0.5 text-xs font-semibold">
            v{plugin.version}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            OpenCart {plugin.minOC}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            Tested {plugin.testedOC}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            PHP {plugin.minPHP}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            {plugin.license}
          </span>
        </div>

        <h1 class="mb-4 text-4xl font-bold leading-tight">
          {plugin.name}
        </h1>
        <p class="text-skin-base mb-3 text-xl font-medium opacity-90">
          {plugin.tagline}
        </p>
        <p class="text-skin-base mb-8 max-w-2xl text-base leading-relaxed opacity-70">
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition hover:brightness-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/>
            </svg>
            View on GitHub
          </a>
          <a
            href={`${plugin.githubUrl}#readme`}
            target="_blank"
            rel="noopener noreferrer"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M6 2a2 2 0 0 0-2 2v16a1 1 0 0 0 1.447.894L12 17.618l6.553 3.276A1 1 0 0 0 20 20V4a2 2 0 0 0-2-2H6z"/>
            </svg>
            Read Documentation
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="text-skin-base mb-8 opacity-60">Operational monitoring for OpenCart without analytics sprawl.</p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((f) => (
          <div class="border-skin-line bg-skin-card rounded-lg border p-5 shadow-sm transition hover:shadow-md">
            <div class="mb-3 text-3xl">{f.icon}</div>
            <h3 class="mb-1.5 text-base font-semibold">{f.title}</h3>
            <p class="text-sm leading-relaxed opacity-65">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="text-skin-base mb-10 opacity-60">Five steps from storefront event injection to live operator insight.</p>
        <ol class="space-y-0">
          {steps.map((s, i) => (
            <li class="flex gap-6">
              <div class="flex flex-col items-center">
                <div class="bg-skin-accent text-skin-inverted flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold">
                  {s.step}
                </div>
                {i < steps.length - 1 && (
                  <div class="border-skin-line my-1 w-px grow border-l border-dashed" />
                )}
              </div>
              <div class="pb-8">
                <h3 class="mb-1 font-semibold">{s.title}</h3>
                <p class="text-sm leading-relaxed opacity-65">{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="border-skin-line bg-skin-card rounded-xl border p-8 shadow-sm">
          <div class="mb-1 text-3xl">🛡️</div>
          <h2 class="mb-2 text-2xl font-bold">Privacy by design</h2>
          <p class="text-skin-base mb-6 opacity-60">
            Theme Performance Pulse is intentionally operational, not analytical.
            The goal is current-store health, not long-term visitor surveillance.
          </p>
          <ul class="space-y-3">
            {privacyPoints.map((point) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed">
                <svg xmlns="http://www.w3.org/2000/svg" class="text-skin-accent mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="opacity-75">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-skin-line divide-y">
                {[
                  ["OpenCart", `${plugin.minOC}`],
                  ["Tested up to", plugin.testedOC],
                  ["PHP", `${plugin.minPHP} or higher`],
                  ["Storage", "OpenCart settings + built-in cache"],
                  ["Database", "No custom analytics tables"],
                  ["Extra services", "None required"],
                ].map(([label, value]) => (
                  <tr>
                    <td class="py-2.5 pr-4 font-medium opacity-70">{label}</td>
                    <td class="py-2.5 opacity-90">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {[
                "Upload the .ocmod.zip package through the OpenCart installer.",
                "Go to Extensions → Extensions → Modules.",
                "Install Theme Performance Pulse.",
                "Open the module settings page.",
                "Enable Module Status and Storefront Monitoring.",
                "Visit storefront pages to start generating live samples.",
              ].map((step, i) => (
                <li class="flex gap-3">
                  <span class="border-skin-line text-skin-accent shrink-0 rounded border px-1.5 py-0.5 text-xs font-bold tabular-nums">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="leading-snug opacity-75">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {[
            {
              q: "Does this extension create its own analytics database tables?",
              a: "No. Theme Performance Pulse uses OpenCart settings for configuration and the built-in cache for the live rolling snapshot. It does not introduce custom analytics tables.",
            },
            {
              q: "Is this meant for long-term analytics reporting?",
              a: "No. The extension is designed for short-lived operational visibility. It helps merchants understand current storefront health, not maintain long-term historical analytics.",
            },
            {
              q: "Does it track personal data or store visitor identities?",
              a: "No. The extension avoids storing IP addresses, visitor identifiers, or other personal data. Captured signals are coarse and anonymous.",
            },
            {
              q: "Can I review the dashboard without affecting live data?",
              a: "Yes. Preview mode exists so you can inspect dashboard behavior safely without altering the live snapshot that operators rely on.",
            },
            {
              q: "Will this require Redis, a queue worker, or a separate backend service?",
              a: "No. The extension is intentionally lightweight and runs inside a standard OpenCart environment using controllers, events, settings, and cache only.",
            },
          ].map((item) => (
            <details class="border-skin-line bg-skin-card group rounded-lg border shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                <span>{item.q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </summary>
              <p class="border-skin-line border-t px-5 py-4 text-sm leading-relaxed opacity-70">
                {item.a}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14 text-center">
        <h2 class="mb-3 text-2xl font-bold">Ready to monitor your storefront health?</h2>
        <p class="text-skin-base mb-8 opacity-60">Open source, lightweight, and built to feel native inside OpenCart.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-6 py-3 text-sm font-semibold transition hover:brightness-110"
          >
            View Source on GitHub
          </a>
          <a
            href="/opencart/"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-6 py-3 text-sm font-semibold transition hover:shadow-md"
          >
            ← Back to extension gallery
          </a>
        </div>
        <p class="mt-6 text-xs opacity-40">
          {plugin.license} &nbsp;·&nbsp; Developed by
          <a href={plugin.authorUrl} class="underline decoration-dashed underline-offset-2 hover:opacity-70" target="_blank" rel="noopener noreferrer">
            Devlin Duldulao
          </a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>