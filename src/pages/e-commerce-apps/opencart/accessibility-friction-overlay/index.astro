---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const plugin = {
  name: "Accessibility Friction Overlay",
  slug: "accessibility-friction-overlay",
  version: "1.0.0",
  testedOpenCart: "4.1.x",
  minPHP: "8.3",
  license: "MIT",
  marketplaceUrl:
    "https://www.opencart.com/index.php?route=marketplace/extension&filter_search=Accessibility%20Friction%20Overlay",
  githubUrl:
    "https://github.com/devlinduldulao/opencart_accessibility_friction_overlay",
  authorUrl: "https://devlinduldulao.pro",
  tagline:
    "Merchant-facing accessibility friction monitoring for OpenCart with a live dashboard and preview walkthroughs.",
  description:
    "A lightweight OpenCart 4 extension that passively collects coarse accessibility friction signals on the storefront, keeps them in a short-lived local buffer, and turns them into merchant-friendly admin insights without adding visible shopper UI.",
};

const features = [
  {
    icon: "📊",
    title: "Live Admin Dashboard",
    desc: "Track recent accessibility friction events, hotspots, and recommendations in a merchant dashboard designed to feel native inside OpenCart admin.",
  },
  {
    icon: "🕵️",
    title: "Passive Storefront Monitor",
    desc: "The storefront collector runs silently in the background. Shoppers do not see a widget, overlay, chat bubble, or injected accessibility toolbar.",
  },
  {
    icon: "🧪",
    title: "Preview Walkthroughs",
    desc: "Simulate realistic scenarios like checkout friction, keyboard audits, catalog walkthroughs, payment failures, and mobile tap audits without waiting for live traffic.",
  },
  {
    icon: "🗂️",
    title: "Short-Lived Local Storage",
    desc: "Signals are written to a temporary local file buffer only. No custom OpenCart database tables, external queue, or analytics warehouse are required.",
  },
  {
    icon: "🔒",
    title: "Privacy-First Collection",
    desc: "No typed form values, passwords, session replay streams, or invasive personal analytics are captured by the extension.",
  },
  {
    icon: "🧩",
    title: "OpenCart Native UI",
    desc: "Built with Bootstrap 5 inside the OpenCart admin so the extension looks and behaves like part of the platform instead of a foreign control panel.",
  },
];

const steps = [
  {
    step: "01",
    title: "A shopper interacts with the storefront",
    desc: "The passive frontend script listens for coarse friction indicators such as repeated focus changes, stalled flows, or navigation trouble without recording sensitive content.",
  },
  {
    step: "02",
    title: "A lightweight event is sanitized",
    desc: "Only the safe, high-level metadata needed for merchant insight is normalized and filtered before it can be stored or displayed.",
  },
  {
    step: "03",
    title: "The event enters the live buffer",
    desc: "The extension writes recent signals into a short-lived local buffer in OpenCart storage so merchants can inspect current friction without maintaining a data warehouse.",
  },
  {
    step: "04",
    title: "The dashboard renders insights",
    desc: "OpenCart admin reads the recent event stream, groups it into useful categories, and surfaces trends, hotspots, and recommendations for follow-up.",
  },
  {
    step: "05",
    title: "Preview mode helps with validation",
    desc: "Store owners can run synthetic preview scenarios to verify the dashboard experience and train teams even when the store has no real traffic yet.",
  },
];

const privacyPoints = [
  "No typed form values or passwords are captured.",
  "No session replay or invasive screen recording is involved.",
  "No custom analytics warehouse, Redis instance, or third-party tracking service is required.",
  "Signals are stored in a short-lived local buffer instead of permanent long-term event tables.",
  "The extension is built for merchant diagnostics, not customer profiling.",
  "Preview mode is admin-only and never appears on the public storefront.",
];
---

<Layout title={`${plugin.name} — Accessibility Monitoring for OpenCart`}>
  <Header />
  <main id="main-content">
    <section class="border-b border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span
            class="rounded bg-skin-accent px-2 py-0.5 text-xs font-semibold text-skin-inverted"
          >
            v{plugin.version}
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            OpenCart {plugin.testedOpenCart}
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            PHP {plugin.minPHP}+
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            {plugin.license}
          </span>
        </div>

        <h1 class="mb-4 text-4xl leading-tight font-bold">
          {plugin.name}
        </h1>
        <p class="mb-3 text-xl font-medium text-skin-base opacity-90">
          {plugin.tagline}
        </p>
        <p
          class="mb-8 max-w-2xl text-base leading-relaxed text-skin-base opacity-70"
        >
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-skin-accent px-5 py-2.5 text-sm font-semibold text-skin-inverted transition hover:brightness-110"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M4 4h16v3H4zm0 5h16v11H4zm3 3v5h4v-5zm6 0h4v2h-4zm0 3h4v2h-4z"
              ></path>
            </svg>
            View on OpenCart Marketplace
          </a>
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border border-skin-line bg-skin-card px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"
              ></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="mb-8 text-skin-base opacity-60">
        Merchant-focused diagnostics without storefront clutter.
      </p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map(feature => (
            <div class="rounded-lg border border-skin-line bg-skin-card p-5 shadow-sm transition hover:shadow-md">
              <div class="mb-3 text-3xl">{feature.icon}</div>
              <h3 class="mb-1.5 text-base font-semibold">{feature.title}</h3>
              <p class="text-sm leading-relaxed opacity-65">{feature.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="mb-10 text-skin-base opacity-60">
          From passive storefront signals to useful merchant insight.
        </p>
        <ol class="space-y-0">
          {
            steps.map((item, index) => (
              <li class="flex gap-6">
                <div class="flex flex-col items-center">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-skin-accent text-sm font-bold text-skin-inverted">
                    {item.step}
                  </div>
                  {index < steps.length - 1 && (
                    <div class="my-1 w-px grow border-l border-dashed border-skin-line" />
                  )}
                </div>
                <div class="pb-8">
                  <h3 class="mb-1 font-semibold">{item.title}</h3>
                  <p class="text-sm leading-relaxed opacity-65">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div
          class="rounded-xl border border-skin-line bg-skin-card p-8 shadow-sm"
        >
          <div class="mb-1 text-3xl">🛡️</div>
          <h2 class="mb-2 text-2xl font-bold">Privacy and restraint</h2>
          <p class="mb-6 text-skin-base opacity-60">
            Built to help merchants investigate friction without drifting into
            invasive shopper surveillance.
          </p>
          <ul class="space-y-3">
            {
              privacyPoints.map(point => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="mt-0.5 h-4 w-4 shrink-0 text-skin-accent"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="opacity-75">{point}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-y divide-skin-line">
                {
                  [
                    ["OpenCart", `${plugin.testedOpenCart} compatible`],
                    ["PHP", `${plugin.minPHP} or higher`],
                    [
                      "Storage",
                      "Writable OpenCart storage cache or temp directory",
                    ],
                    ["Database", "No custom extension tables required"],
                    [
                      "Services",
                      "No Node.js, Redis, or external queue required",
                    ],
                    ["Admin UI", "OpenCart admin with Bootstrap 5 styling"],
                  ].map(([label, value]) => (
                    <tr>
                      <td class="py-2.5 pr-4 font-medium opacity-70">
                        {label}
                      </td>
                      <td class="py-2.5 opacity-90">{value}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {
                [
                  "Download the OpenCart extension package from the marketplace or your release artifact.",
                  "In OpenCart admin, go to Extensions -> Installer and upload the .ocmod.zip package.",
                  "After upload, open Extensions -> Extensions and choose Modules.",
                  "Find Accessibility Friction Overlay, click Install, then click Edit.",
                  "Grant the needed access and modify permissions to your admin user group if required.",
                  "Use Preview Mode to simulate sample friction scenarios and validate the dashboard immediately.",
                ].map((step, index) => (
                  <li class="flex gap-3">
                    <span class="shrink-0 rounded border border-skin-line px-1.5 py-0.5 text-xs font-bold text-skin-accent tabular-nums">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="leading-snug opacity-75">{step}</span>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {
            [
              {
                q: "Does this add a visible accessibility widget to the storefront?",
                a: "No. The extension monitors passively and does not inject a shopper-facing overlay, toolbar, or floating button.",
              },
              {
                q: "Does it require a separate analytics service?",
                a: "No. It runs entirely inside OpenCart using local storage and built-in platform capabilities. No third-party analytics account is needed.",
              },
              {
                q: "What kind of data does it avoid collecting?",
                a: "It avoids typed form values, passwords, session replay footage, and invasive long-term customer profiling data. The goal is actionable merchant diagnostics, not surveillance.",
              },
              {
                q: "Can I preview the dashboard without real shoppers?",
                a: "Yes. Preview mode generates synthetic scenarios so merchants and QA teams can inspect the dashboard before the store has real accessibility signal traffic.",
              },
              {
                q: "Will it fit the OpenCart admin visually?",
                a: "Yes. The admin UI is built around Bootstrap 5 and the native OpenCart admin look so it does not feel like a foreign embedded app.",
              },
            ].map(item => (
              <details class="group rounded-lg border border-skin-line bg-skin-card shadow-sm">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                  <span>{item.q}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </summary>
                <p class="border-t border-skin-line px-5 py-4 text-sm leading-relaxed opacity-70">
                  {item.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14 text-center">
        <h2 class="mb-3 text-2xl font-bold">
          Ready to audit storefront friction more clearly?
        </h2>
        <p class="mb-8 text-skin-base opacity-60">
          Use a native OpenCart extension instead of bolting on another external
          analytics tool.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href={plugin.marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-skin-accent px-6 py-3 text-sm font-semibold text-skin-inverted transition hover:brightness-110"
          >
            View on OpenCart Marketplace
          </a>
          <a
            href="/e-commerce-apps/opencart/"
            class="inline-flex items-center gap-2 rounded-md border border-skin-line bg-skin-card px-6 py-3 text-sm font-semibold transition hover:shadow-md"
          >
            ← Back to plugin gallery
          </a>
        </div>
        <p class="mt-6 text-xs opacity-40">
          {plugin.license} &nbsp;·&nbsp; Developed by
          <a
            href={plugin.authorUrl}
            class="underline decoration-dashed underline-offset-2 hover:opacity-70"
            target="_blank"
            rel="noopener noreferrer"
          >
            Devlin Duldulao
          </a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
