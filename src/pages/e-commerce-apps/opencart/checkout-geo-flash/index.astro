---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const plugin = {
  name: "Checkout Geo Flash",
  slug: "checkout-geo-flash",
  version: "1.0.0",
  testedOC: "4.x",
  minPHP: "8.3",
  license: "MIT",
  githubUrl: "https://github.com/devlinduldulao/opencart_checkout_geo_flash",
  authorUrl: "https://devlinduldulao.pro",
  tagline:
    "Owner-only OpenCart dashboard for recent checkout and paid-order activity.",
  description:
    "A standalone OpenCart 4 extension that captures privacy-safe order events, keeps only short-lived recent activity, and renders the experience exclusively in the admin dashboard without extra services.",
};

const features = [
  {
    icon: "📍",
    title: "Live Activity Feed",
    desc: "Show recent checkout-created and paid-order moments in an owner dashboard that stays inside the normal OpenCart admin experience.",
  },
  {
    icon: "🧪",
    title: "Preview Mode",
    desc: "Use the built-in fake-data preview to demo, validate, and capture screenshots without waiting for real customer orders.",
  },
  {
    icon: "🔒",
    title: "Privacy-Safe Payloads",
    desc: "The browser-visible feed excludes names, emails, raw IPs, order totals, and order IDs while still giving operators useful visibility.",
  },
  {
    icon: "🗂️",
    title: "Short Retention",
    desc: "Recent events are pruned aggressively so the module remains lightweight and avoids turning into a long-lived analytics archive.",
  },
  {
    icon: "🧩",
    title: "OpenCart Native Admin UI",
    desc: "Built as an OpenCart module page for store owners, not as a separate app shell or storefront widget.",
  },
  {
    icon: "⚙️",
    title: "No Extra Infrastructure",
    desc: "Runs entirely inside OpenCart using the existing database and native event hooks, with no Redis, Node.js, workers, or external service.",
  },
];

const steps = [
  {
    step: "01",
    title: "OpenCart event hook fires",
    desc: "Native OpenCart order hooks capture checkout-created and paid-order moments at the application layer instead of relying on external collectors.",
  },
  {
    step: "02",
    title: "The order is sanitized",
    desc: "The catalog model keeps only the fields needed for owner visibility: event type, first product name, coarse location label, and timestamp.",
  },
  {
    step: "03",
    title: "A recent event row is stored",
    desc: "The extension writes short-lived activity rows into the store's existing OpenCart database and deduplicates repeated order-phase emissions.",
  },
  {
    step: "04",
    title: "The admin feed is polled",
    desc: "The owner dashboard requests only events newer than its last cursor so the UI stays responsive without heavy refresh logic.",
  },
  {
    step: "05",
    title: "The dashboard renders owner insight",
    desc: "OpenCart admin shows the recent activity cards or fake preview data while keeping the storefront free of public monitoring UI.",
  },
];

const privacyPoints = [
  "No raw IP retention.",
  "No shopper names or emails in owner feed payloads.",
  "No order totals or order IDs exposed in the browser.",
  "No public storefront rendering or shopper-facing widget.",
  "Recent events are retained only for a short window.",
  "No Redis, Node.js service, or external telemetry platform is required.",
];

const requirements = [
  ["OpenCart", plugin.testedOC],
  ["PHP", `${plugin.minPHP} or higher`],
  ["Database", "Existing MySQL or MariaDB store database"],
  ["Runtime", "Standalone OpenCart extension"],
  ["Composer", "Local testing and linting only"],
  ["External services", "None required"],
];

const installSteps = [
  "Build or download the .ocmod.zip package for Checkout Geo Flash.",
  "In OpenCart admin, go to Extensions -> Installer and upload the package.",
  "Open Extensions -> Extensions -> Modules and install Checkout Geo Flash.",
  "Grant admin access and modify permissions for extension/module/checkout_geo_flash if needed.",
  "Open the module page, enable it, and save the settings.",
  "Use the dashboard feed or preview mode to validate the owner experience.",
];

const faqItems = [
  {
    q: "Does this show anything on the storefront?",
    a: "No. Checkout Geo Flash is designed for the business owner. The activity experience lives in OpenCart admin only.",
  },
  {
    q: "What event types does it capture?",
    a: "It captures checkout-created and paid-order events through OpenCart's native order hooks.",
  },
  {
    q: "What data is stored?",
    a: "The module stores only product name, coarse location, event type, and timestamp for recent owner visibility.",
  },
  {
    q: "Do I need Redis, Node.js, or a worker queue?",
    a: "No. The extension is intentionally standalone and runs inside a standard OpenCart deployment using the existing database.",
  },
  {
    q: "Why include preview mode?",
    a: "Preview mode makes demos, onboarding, QA, and screenshots possible before live orders arrive and without exposing real customer data.",
  },
];
---

<Layout title={`${plugin.name} — Owner Activity Dashboard for OpenCart`}>
  <Header />
  <main id="main-content">
    <section class="border-skin-line border-b">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span class="bg-skin-accent text-skin-inverted rounded px-2 py-0.5 text-xs font-semibold">
            v{plugin.version}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            OpenCart {plugin.testedOC}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            PHP {plugin.minPHP}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            {plugin.license}
          </span>
        </div>

        <h1 class="mb-4 text-4xl font-bold leading-tight">
          {plugin.name}
        </h1>
        <p class="text-skin-base mb-3 text-xl font-medium opacity-90">
          {plugin.tagline}
        </p>
        <p class="text-skin-base mb-8 max-w-2xl text-base leading-relaxed opacity-70">
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition hover:brightness-110"
          >
            View on GitHub
          </a>
          <a
            href={plugin.authorUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
          >
            Developer Site
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="text-skin-base mb-8 opacity-60">Recent order visibility for operators without adding infrastructure sprawl.</p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <div class="border-skin-line bg-skin-card rounded-lg border p-5 shadow-sm transition hover:shadow-md">
            <div class="mb-3 text-3xl">{feature.icon}</div>
            <h3 class="mb-1.5 text-base font-semibold">{feature.title}</h3>
            <p class="text-sm leading-relaxed opacity-65">{feature.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="text-skin-base mb-10 opacity-60">Five steps from OpenCart order event to owner dashboard activity.</p>
        <ol class="space-y-0">
          {steps.map((item, index) => (
            <li class="flex gap-6">
              <div class="flex flex-col items-center">
                <div class="bg-skin-accent text-skin-inverted flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold">
                  {item.step}
                </div>
                {index < steps.length - 1 && (
                  <div class="border-skin-line my-1 w-px grow border-l border-dashed" />
                )}
              </div>
              <div class="pb-8">
                <h3 class="mb-1 font-semibold">{item.title}</h3>
                <p class="text-sm leading-relaxed opacity-65">{item.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="border-skin-line bg-skin-card rounded-xl border p-8 shadow-sm">
          <div class="mb-1 text-3xl">🛡️</div>
          <h2 class="mb-2 text-2xl font-bold">Privacy model</h2>
          <p class="text-skin-base mb-6 opacity-60">
            Checkout Geo Flash is intentionally narrow in scope: recent owner activity only, with customer-sensitive data kept out of the browser payload.
          </p>
          <ul class="space-y-3">
            {privacyPoints.map((point) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed">
                <svg xmlns="http://www.w3.org/2000/svg" class="text-skin-accent mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="opacity-75">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-skin-line divide-y">
                {requirements.map(([label, value]) => (
                  <tr>
                    <td class="py-2.5 pr-4 font-medium opacity-70">{label}</td>
                    <td class="py-2.5 opacity-90">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {installSteps.map((step, index) => (
                <li class="flex gap-3">
                  <span class="border-skin-line text-skin-accent shrink-0 rounded border px-1.5 py-0.5 text-xs font-bold tabular-nums">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="leading-snug opacity-75">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {faqItems.map((item) => (
            <details class="border-skin-line bg-skin-card group rounded-lg border shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                <span>{item.q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </summary>
              <div class="border-skin-line border-t px-5 py-4 text-sm leading-relaxed opacity-75">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>