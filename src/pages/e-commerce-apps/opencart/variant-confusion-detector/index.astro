---
const plugin = {
  name: "Variant Confusion Detector",
  slug: "variant-confusion-detector",
  version: "1.0.0",
  testedOpenCart: "4.1.0.3",
  minPHP: "8.3",
  license: "MIT",
  githubUrl: "https://github.com/devlinduldulao/opencart_variant_confusion_detector",
  docsUrl: "https://github.com/devlinduldulao/opencart_variant_confusion_detector/blob/main/README.md",
  authorUrl: "https://devlinduldulao.pro",
  tagline: "See where shoppers get stuck before conversion drops.",
  description:
    "An OpenCart-native admin module that captures short-lived, anonymous product-option interaction signals and turns them into a practical dashboard for hesitation, stock friction, and blocked cart attempts.",
};

const features = [
  {
    title: "Admin-Only Detector Dashboard",
    desc: "Monitor recent events, product scores, and detector metrics from a native OpenCart admin screen without adding any storefront widget.",
  },
  {
    title: "Anonymous Event Collection",
    desc: "Track only short-lived session hints, event types, and bounded context values. No external analytics service or persistent shopper profiling.",
  },
  {
    title: "Variant Thrash Signal",
    desc: "Highlight products where customers repeatedly switch variants in quick succession, a strong indicator of option confusion.",
  },
  {
    title: "Stock Frustration Signal",
    desc: "Surface repeated out-of-stock selections so operators can quickly spot inventory friction on configurable products.",
  },
  {
    title: "Preview Mode",
    desc: "Generate realistic sample dashboard data for screenshots, demos, and pre-launch walkthroughs without needing real shopper traffic.",
  },
  {
    title: "Bootstrap 5 Native UI",
    desc: "Built to align with the OpenCart admin look and feel using Bootstrap 5 design patterns instead of a disconnected custom interface.",
  },
];

const steps = [
  {
    step: "01",
    title: "Product page interaction happens",
    desc: "A shopper changes a variant, hits a blocked cart state, opens a size guide, or triggers another monitored option event.",
  },
  {
    step: "02",
    title: "A lightweight event is posted",
    desc: "The storefront tracker sends a small JSON payload to the module endpoint with a product ID, event type, and bounded context fields.",
  },
  {
    step: "03",
    title: "The event is sanitized and stored",
    desc: "The module validates the payload, applies rate and queue limits, and stores short-lived anonymous telemetry inside the OpenCart database.",
  },
  {
    step: "04",
    title: "Signals are derived",
    desc: "Detector logic aggregates the raw events into higher-level signals such as variant thrash, stock frustration, and blocked cart pressure.",
  },
  {
    step: "05",
    title: "The admin dashboard updates",
    desc: "Store operators can review current scores, recent events, and affected products directly from the OpenCart module settings page.",
  },
];

const privacyPoints = [
  "No external analytics platform is required.",
  "Only anonymous, short-lived session hints are stored.",
  "The detector focuses on product-option telemetry, not personal shopper profiles.",
  "Retention windows and queue limits are configurable from the admin module.",
  "The extension is designed for operator insight without adding a customer-facing dashboard block.",
  "Preview mode makes demos and screenshots possible without exposing real shopper activity.",
];

const faqItems = [
  {
    q: "Does this show anything on the storefront?",
    a: "No. The extension is positioned as an owner-facing dashboard tool. It injects tracking behavior where needed, but it does not render a public-facing module block for shoppers.",
  },
  {
    q: "Do I need a third-party analytics service?",
    a: "No. All detector events are handled inside OpenCart. There is no Redis, Node.js collector, or external analytics vendor required to use the module.",
  },
  {
    q: "What kinds of issues can it reveal?",
    a: "It can reveal rapid variant switching, repeated out-of-stock option selections, blocked add-to-cart attempts, and size-guide engagement patterns that often correlate with purchase friction.",
  },
  {
    q: "Can I demo the dashboard before live traffic exists?",
    a: "Yes. Preview mode generates sample data so you can verify the layout, capture screenshots, and walk stakeholders through the module before launch.",
  },
  {
    q: "Is it compatible with OpenCart Cloud upload packaging?",
    a: "Yes. The project includes a cloud-compatible .ocmod.zip package with the required upload directory and root install.xml for OpenCart cloud submission workflows.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{plugin.name} - Product Option Analytics for OpenCart</title>
  </head>
  <body>
    <main id="main-content">
      <section class="border-skin-line border-b">
        <div class="mx-auto max-w-4xl px-4 py-16">
          <div class="mb-4 flex flex-wrap items-center gap-2">
            <span class="bg-skin-accent text-skin-inverted rounded px-2 py-0.5 text-xs font-semibold">
              v{plugin.version}
            </span>
            <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
              OpenCart {plugin.testedOpenCart}
            </span>
            <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
              PHP {plugin.minPHP}+
            </span>
            <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
              {plugin.license}
            </span>
          </div>

          <h1 class="mb-4 text-4xl font-bold leading-tight">
            {plugin.name}
          </h1>
          <p class="text-skin-base mb-3 text-xl font-medium opacity-90">
            {plugin.tagline}
          </p>
          <p class="text-skin-base mb-8 max-w-2xl text-base leading-relaxed opacity-70">
            {plugin.description}
          </p>

          <div class="flex flex-wrap gap-3">
            <a
              href={plugin.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition hover:brightness-110"
            >
              View on GitHub
            </a>
            <a
              href={plugin.docsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
            >
              Read Documentation
            </a>
          </div>
        </div>
      </section>

      <section class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">Features</h2>
        <p class="text-skin-base mb-8 opacity-60">Focused operator insight without external analytics overhead.</p>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {features.map((feature) => (
            <div class="border-skin-line bg-skin-card rounded-lg border p-5 shadow-sm transition hover:shadow-md">
              <h3 class="mb-2 text-base font-semibold">{feature.title}</h3>
              <p class="text-sm leading-relaxed opacity-65">{feature.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="border-skin-line border-t">
        <div class="mx-auto max-w-4xl px-4 py-14">
          <h2 class="mb-2 text-2xl font-bold">How it works</h2>
          <p class="text-skin-base mb-10 opacity-60">Five steps from shopper hesitation to operator insight.</p>
          <ol class="space-y-0">
            {steps.map((step, index) => (
              <li class="flex gap-6">
                <div class="flex flex-col items-center">
                  <div class="bg-skin-accent text-skin-inverted flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold">
                    {step.step}
                  </div>
                  {index < steps.length - 1 && (
                    <div class="border-skin-line my-1 w-px grow border-l border-dashed" />
                  )}
                </div>
                <div class="pb-8">
                  <h3 class="mb-1 font-semibold">{step.title}</h3>
                  <p class="text-sm leading-relaxed opacity-65">{step.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <section class="border-skin-line border-t">
        <div class="mx-auto max-w-4xl px-4 py-14">
          <div class="border-skin-line bg-skin-card rounded-xl border p-8 shadow-sm">
            <h2 class="mb-2 text-2xl font-bold">Privacy and scope</h2>
            <p class="text-skin-base mb-6 opacity-60">
              Built for operational visibility into product-option friction while keeping the telemetry intentionally narrow and short-lived.
            </p>
            <ul class="space-y-3">
              {privacyPoints.map((point) => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <svg xmlns="http://www.w3.org/2000/svg" class="text-skin-accent mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="opacity-75">{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="border-skin-line border-t">
        <div class="mx-auto max-w-4xl px-4 py-14">
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
            <div>
              <h2 class="mb-4 text-xl font-bold">Requirements</h2>
              <table class="w-full text-sm">
                <tbody class="divide-skin-line divide-y">
                  {[
                    ["OpenCart", `${plugin.testedOpenCart} tested`],
                    ["PHP", `${plugin.minPHP} or higher`],
                    ["Database", "MySQL 8.4 or MariaDB 11.x compatible"],
                    ["Installer format", "OCMOD zip package"],
                    ["Admin UI", "Bootstrap 5 native OpenCart styling"],
                    ["Storefront block", "None rendered publicly"],
                  ].map(([label, value]) => (
                    <tr>
                      <td class="py-2.5 pr-4 font-medium opacity-70">{label}</td>
                      <td class="py-2.5 opacity-90">{value}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div>
              <h2 class="mb-4 text-xl font-bold">Installation</h2>
              <ol class="space-y-3 text-sm">
                {[
                  "Download the OpenCart release zip for the extension.",
                  "In OpenCart admin, go to Extensions -> Installer and upload the package.",
                  "Open Extensions -> Extensions -> Modules and install Variant Confusion Detector.",
                  "Grant the appropriate access and modify permissions for the module route if needed.",
                  "Enable monitoring, configure the detector settings, and save.",
                  "Refresh modifications only if your deployment workflow uses OCMOD cache refreshes.",
                ].map((step, index) => (
                  <li class="flex gap-3">
                    <span class="border-skin-line text-skin-accent shrink-0 rounded border px-1.5 py-0.5 text-xs font-bold tabular-nums">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="leading-snug opacity-75">{step}</span>
                  </li>
                ))}
              </ol>
            </div>
          </div>
        </div>
      </section>

      <section class="border-skin-line border-t">
        <div class="mx-auto max-w-4xl px-4 py-14">
          <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
          <div class="space-y-6">
            {faqItems.map((item) => (
              <details class="border-skin-line bg-skin-card group rounded-lg border shadow-sm">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                  <span>{item.q}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                  </svg>
                </summary>
                <p class="border-skin-line border-t px-5 py-4 text-sm leading-relaxed opacity-70">
                  {item.a}
                </p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="border-skin-line border-t">
        <div class="mx-auto max-w-4xl px-4 py-14 text-center">
          <h2 class="mb-3 text-2xl font-bold">Ready to inspect option friction inside OpenCart?</h2>
          <p class="text-skin-base mb-8 opacity-60">Lightweight, admin-facing, and built around native OpenCart workflows.</p>
          <div class="flex flex-wrap justify-center gap-3">
            <a
              href={plugin.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-6 py-3 text-sm font-semibold transition hover:brightness-110"
            >
              View the Project
            </a>
            <a
              href="/e-commerce-apps/opencart/"
              class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-6 py-3 text-sm font-semibold transition hover:shadow-md"
            >
              Back to OpenCart gallery
            </a>
          </div>
          <p class="mt-6 text-xs opacity-40">
            {plugin.license} · Developed by
            <a href={plugin.authorUrl} class="underline decoration-dashed underline-offset-2 hover:opacity-70" target="_blank" rel="noopener noreferrer">
              Devlin Duldulao
            </a>
          </p>
        </div>
      </section>
    </main>
  </body>
</html>