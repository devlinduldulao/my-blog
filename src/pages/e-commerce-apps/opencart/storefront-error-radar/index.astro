---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Layout from "@/layouts/Layout.astro";

const plugin = {
  name: "Storefront Error Radar",
  slug: "storefront-error-radar",
  version: "1.0.0",
  testedOC: "4.1.0.3",
  minPHP: "8.3",
  minOC: "4.0",
  license: "MIT",
  marketplaceUrl:
    "https://www.opencart.com/index.php?route=marketplace/extension",
  githubUrl:
    "https://github.com/devlinduldulao/opencart_storefront_error_radar",
  authorUrl: "https://devlinduldulao.pro",
  tagline:
    "Spot live storefront breakage before your revenue path stays broken too long.",
  description:
    "A privacy-first OpenCart extension that captures anonymous storefront failures, keeps only a short-lived local incident buffer, and surfaces the result inside an owner-facing admin console without any external telemetry service.",
};

const pageTitle = `${plugin.name} — Privacy-First Storefront Incident Monitoring for OpenCart`;

const features = [
  {
    icon: "🧭",
    title: "Live Incident Snapshot",
    desc: "See the current active incident window directly inside the module page, including counts for recent signals, resource failures, critical path failures, and burst alerts.",
  },
  {
    icon: "🛒",
    title: "Revenue-Path Monitoring",
    desc: "Prioritize checkout and add-to-cart failures instead of treating every browser error as equally important operational noise.",
  },
  {
    icon: "🔒",
    title: "Privacy-First Storage",
    desc: "No cookies, no IP storage, no checkout field capture, and no third-party telemetry pipeline. Payloads are sanitized before they are written locally.",
  },
  {
    icon: "⚡",
    title: "No Extra Infrastructure",
    desc: "Runs entirely inside your existing OpenCart stack with no Redis requirement, no Node.js collector, and no separate incident database.",
  },
  {
    icon: "🧪",
    title: "Preview Mode",
    desc: "Demonstrate the dashboard with synthetic incidents when you need screenshots, demos, or UI validation without waiting for real storefront failures.",
  },
  {
    icon: "🧱",
    title: "OpenCart Native Admin UI",
    desc: "Built to sit naturally inside the OpenCart 4 admin experience using a Bootstrap-based module settings page instead of a separate application shell.",
  },
];

const steps = [
  {
    step: "01",
    title: "Storefront collector loads",
    desc: "A lightweight collector is injected on the storefront footer through the normal OpenCart application flow.",
  },
  {
    step: "02",
    title: "Anonymous failure is captured",
    desc: "JavaScript errors, promise rejections, resource failures, and critical request failures are normalized into a small payload.",
  },
  {
    step: "03",
    title: "Payload is sanitized",
    desc: "Sensitive values are stripped before storage so the incident window remains operationally useful without turning into a customer data archive.",
  },
  {
    step: "04",
    title: "Incident buffer is updated",
    desc: "Events are written to a short-lived JSON buffer inside DIR_STORAGE and summarized into operator-facing rollups.",
  },
  {
    step: "05",
    title: "Admin dashboard refreshes",
    desc: "The module page polls the snapshot endpoint and updates the current live window without leaving OpenCart admin.",
  },
];

const privacyPoints = [
  "No IP addresses are intentionally stored.",
  "No cookies are intentionally stored by the extension.",
  "No customer-entered checkout values are intentionally stored.",
  "Incident retention is deliberately short-lived rather than historical.",
  "All captured storefront payloads are sanitized before storage.",
  "No third-party telemetry backend or external monitoring service is required.",
];

const faqs = [
  {
    q: "Does this extension add anything visible to the storefront?",
    a: "No. The storefront side is only a silent collector for anonymous incident signals. The operator console lives entirely in OpenCart admin.",
  },
  {
    q: "Does it keep historical analytics forever?",
    a: "No. The extension is intentionally built around a short-lived local incident buffer rather than a permanent observability archive.",
  },
  {
    q: "What kinds of failures can it detect?",
    a: "It captures JavaScript runtime failures, unhandled promise rejections, asset load failures, failed cart or API requests, slow critical-path requests, and derived burst alerts.",
  },
  {
    q: "Do I need Redis, Node.js, or an external dashboard service?",
    a: "No. Storefront Error Radar runs entirely inside a normal OpenCart deployment and stores its short-lived incident window locally.",
  },
  {
    q: "What is preview mode for?",
    a: "Preview mode injects synthetic incidents so you can demo the dashboard state, validate the UI, and prepare screenshots without waiting for real production issues.",
  },
];

const requirements = [
  ["OpenCart", `${plugin.minOC} or higher`],
  ["Tested on", plugin.testedOC],
  ["PHP", `${plugin.minPHP} or higher`],
  ["Storage", "Writable DIR_STORAGE path"],
  ["Database", "No extra custom extension tables required"],
  ["Infrastructure", "No Redis or Node.js collector required"],
];

const installSteps = [
  "Download the .ocmod.zip package for Storefront Error Radar.",
  "In OpenCart admin, go to Extensions → Installer and upload the package.",
  "Open Extensions → Extensions and choose the Modules type filter.",
  "Install Storefront Error Radar.",
  "Open the module settings page and enable monitoring.",
  "Review the live snapshot, preview mode, retention, and sampling settings.",
];
---

<Layout title={pageTitle}>
  <Header />
  <main id="main-content">
    <section class="border-b border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span
            class="rounded bg-skin-accent px-2 py-0.5 text-xs font-semibold text-skin-inverted"
            >v{plugin.version}</span
          >
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
            >OpenCart {plugin.minOC}+</span
          >
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
            >Tested on {plugin.testedOC}</span
          >
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
            >PHP {plugin.minPHP}+</span
          >
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
            >{plugin.license}</span
          >
        </div>

        <h1 class="mb-4 text-4xl leading-tight font-bold">{plugin.name}</h1>
        <p class="mb-3 text-xl font-medium text-skin-base opacity-90">
          {plugin.tagline}
        </p>
        <p
          class="mb-8 max-w-2xl text-base leading-relaxed text-skin-base opacity-70"
        >
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-skin-accent px-5 py-2.5 text-sm font-semibold text-skin-inverted transition hover:brightness-110"
            >OpenCart Marketplace</a
          >
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border border-skin-line bg-skin-card px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
            >View on GitHub</a
          >
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="mb-8 text-skin-base opacity-60">
        Built for operators who need actionable incident visibility without a
        heavyweight monitoring stack.
      </p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map(feature => (
            <div class="rounded-lg border border-skin-line bg-skin-card p-5 shadow-sm transition hover:shadow-md">
              <div class="mb-3 text-3xl">{feature.icon}</div>
              <h3 class="mb-1.5 text-base font-semibold">{feature.title}</h3>
              <p class="text-sm leading-relaxed opacity-65">{feature.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="mb-10 text-skin-base opacity-60">
          Five steps from storefront failure to admin-side incident visibility.
        </p>
        <ol class="space-y-0">
          {
            steps.map((item, index) => (
              <li class="flex gap-6">
                <div class="flex flex-col items-center">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-skin-accent text-sm font-bold text-skin-inverted">
                    {item.step}
                  </div>
                  {index < steps.length - 1 && (
                    <div class="my-1 w-px grow border-l border-dashed border-skin-line" />
                  )}
                </div>
                <div class="pb-8">
                  <h3 class="mb-1 font-semibold">{item.title}</h3>
                  <p class="text-sm leading-relaxed opacity-65">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div
          class="rounded-xl border border-skin-line bg-skin-card p-8 shadow-sm"
        >
          <div class="mb-1 text-3xl">🛡️</div>
          <h2 class="mb-2 text-2xl font-bold">Privacy by design</h2>
          <p class="mb-6 text-skin-base opacity-60">
            Storefront Error Radar is designed to help operators diagnose
            storefront reliability problems without building a permanent
            customer event archive.
          </p>
          <ul class="space-y-3">
            {
              privacyPoints.map(point => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="mt-0.5 h-4 w-4 shrink-0 text-skin-accent"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="opacity-75">{point}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-y divide-skin-line">
                {
                  requirements.map(([label, value]) => (
                    <tr>
                      <td class="py-2.5 pr-4 font-medium opacity-70">
                        {label}
                      </td>
                      <td class="py-2.5 opacity-90">{value}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {
                installSteps.map((step, index) => (
                  <li class="flex gap-3">
                    <span class="shrink-0 rounded border border-skin-line px-1.5 py-0.5 text-xs font-bold text-skin-accent tabular-nums">
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <span class="leading-snug opacity-75">{step}</span>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {
            faqs.map(item => (
              <details class="group rounded-lg border border-skin-line bg-skin-card shadow-sm">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                  <span>{item.q}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </summary>
                <p class="border-t border-skin-line px-5 py-4 text-sm leading-relaxed opacity-70">
                  {item.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14 text-center">
        <h2 class="mb-3 text-2xl font-bold">
          Need a lighter way to watch storefront reliability?
        </h2>
        <p class="mb-8 text-skin-base opacity-60">
          Storefront Error Radar is built for OpenCart operators who want
          immediate signal, not another infrastructure project.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-skin-accent px-6 py-3 text-sm font-semibold text-skin-inverted transition hover:brightness-110"
            >View Source on GitHub</a
          >
          <a
            href="/e-commerce-apps/opencart/"
            class="inline-flex items-center gap-2 rounded-md border border-skin-line bg-skin-card px-6 py-3 text-sm font-semibold transition hover:shadow-md"
            >← Back to extension gallery</a
          >
        </div>
        <p class="mt-6 text-xs opacity-40">
          {plugin.license} &nbsp;·&nbsp; Developed by
          <a
            href={plugin.authorUrl}
            class="underline decoration-dashed underline-offset-2 hover:opacity-70"
            target="_blank"
            rel="noopener noreferrer">Devlin Duldulao</a
          >
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
