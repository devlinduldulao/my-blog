---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const plugin = {
  name: "Realtime Mouse Tracker",
  slug: "realtime-mouse-tracker",
  version: "1.1.0",
  testedOC: "4.1.0.3",
  minPHP: "8.3",
  minOC: "4.0",
  license: "MIT",
  marketplaceUrl:
    "https://www.opencart.com/index.php?route=marketplace/extension",
  githubUrl:
    "https://github.com/devlinduldulao/opencart_realtime_mouse_tracker",
  authorUrl: "https://devlinduldulao.pro",
  tagline:
    "Operator-focused live storefront signals without extra infrastructure.",
  description:
    "A privacy-first OpenCart extension that tracks storefront interaction signals in near real time and surfaces them in an admin-only dashboard using short-lived local state only.",
};

const features = [
  {
    icon: "📊",
    title: "Live Operator Dashboard",
    desc: "Watch active visitors, queued visitors, events per minute, rage clicks, dead clicks, and recent event flow from one OpenCart-native admin screen.",
  },
  {
    icon: "🖱️",
    title: "Real Interaction Signals",
    desc: "Tracks page views, cursor movement, scroll depth, clicks, taps, rage clicks, and dead clicks to expose friction patterns quickly.",
  },
  {
    icon: "🧪",
    title: "Preview Mode",
    desc: "Simulate realistic operator-facing scenarios inside the admin UI so you can demo, review, and capture screenshots without live shopper traffic.",
  },
  {
    icon: "⚙️",
    title: "Configurable Scope",
    desc: "Limit tracking to catalog pages, product pages, category browsing, or cart and checkout routes to control signal quality and request volume.",
  },
  {
    icon: "🔒",
    title: "Short-Lived Local State",
    desc: "Uses a rolling JSON snapshot on the OpenCart host instead of a separate analytics backend, long-lived history, or replay archive.",
  },
  {
    icon: "⚡",
    title: "Low Infrastructure Footprint",
    desc: "No Redis, Node.js, WebSockets, or external analytics service required, which keeps deployment practical for single-store hosting.",
  },
];

const steps = [
  {
    step: "01",
    title: "Visitor opens a matching storefront page",
    desc: "The tracker script is injected automatically through the OpenCart footer event when the configured route scope matches.",
  },
  {
    step: "02",
    title: "Browser batches interactions",
    desc: "Mouse movement, scrolling, clicks, taps, and heartbeat-like activity are grouped into small payloads instead of firing noisy requests on every event.",
  },
  {
    step: "03",
    title: "Collect endpoint sanitizes the payload",
    desc: "OpenCart receives the batch through the public collect route, validates origin data, and normalizes event values before any state is updated.",
  },
  {
    step: "04",
    title: "Rolling live state is updated",
    desc: "The extension stores only the current live snapshot in a short-lived local JSON state file and prunes stale visitors automatically.",
  },
  {
    step: "05",
    title: "Admin dashboard polls and refreshes",
    desc: "The operator dashboard reads the snapshot route and redraws metrics, recent visitors, and recommendations without requiring external infrastructure.",
  },
];

const privacyPoints = [
  "No Redis, Node.js service, WebSocket broker, or external analytics backend is required.",
  "No long-lived visitor history or session replay archive is stored.",
  "The extension uses only a short-lived rolling state file for live operational awareness.",
  "Do Not Track can be honored through the module settings.",
  "The dashboard is admin-only and never renders as a storefront widget.",
  "Origin validation and payload sanitization run before state changes are accepted.",
];
---

<Layout
  title={`${plugin.name} — Live Storefront Interaction Signals for OpenCart`}
>
  <Header />
  <main id="main-content">
    <section class="border-b border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span
            class="rounded bg-skin-accent px-2 py-0.5 text-xs font-semibold text-skin-inverted"
          >
            v{plugin.version}
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            OpenCart {plugin.minOC}+
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            Tested on {plugin.testedOC}
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            PHP {plugin.minPHP}+
          </span>
          <span
            class="rounded border border-skin-line px-2 py-0.5 text-xs opacity-70"
          >
            {plugin.license}
          </span>
        </div>

        <h1 class="mb-4 text-4xl leading-tight font-bold">
          {plugin.name}
        </h1>
        <p class="mb-3 text-xl font-medium text-skin-base opacity-90">
          {plugin.tagline}
        </p>
        <p
          class="mb-8 max-w-2xl text-base leading-relaxed text-skin-base opacity-70"
        >
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-skin-accent px-5 py-2.5 text-sm font-semibold text-skin-inverted transition hover:brightness-110"
          >
            View on OpenCart Marketplace
          </a>
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md border border-skin-line bg-skin-card px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
          >
            View on GitHub
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="mb-8 text-skin-base opacity-60">
        Built for operators who need live signal, not a heavy analytics stack.
      </p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map(f => (
            <div class="rounded-lg border border-skin-line bg-skin-card p-5 shadow-sm transition hover:shadow-md">
              <div class="mb-3 text-3xl">{f.icon}</div>
              <h3 class="mb-1.5 text-base font-semibold">{f.title}</h3>
              <p class="text-sm leading-relaxed opacity-65">{f.desc}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="mb-10 text-skin-base opacity-60">
          Five steps from storefront interaction to admin insight.
        </p>
        <ol class="space-y-0">
          {
            steps.map((s, i) => (
              <li class="flex gap-6">
                <div class="flex flex-col items-center">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-skin-accent text-sm font-bold text-skin-inverted">
                    {s.step}
                  </div>
                  {i < steps.length - 1 && (
                    <div class="my-1 w-px grow border-l border-dashed border-skin-line" />
                  )}
                </div>
                <div class="pb-8">
                  <h3 class="mb-1 font-semibold">{s.title}</h3>
                  <p class="text-sm leading-relaxed opacity-65">{s.desc}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div
          class="rounded-xl border border-skin-line bg-skin-card p-8 shadow-sm"
        >
          <div class="mb-1 text-3xl">🛡️</div>
          <h2 class="mb-2 text-2xl font-bold">
            Privacy and infrastructure model
          </h2>
          <p class="mb-6 text-skin-base opacity-60">
            This extension is intentionally built for low-cost hosting and
            short-lived operational awareness rather than persistent analytics
            warehousing.
          </p>
          <ul class="space-y-3">
            {
              privacyPoints.map(point => (
                <li class="flex items-start gap-3 text-sm leading-relaxed">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="mt-0.5 h-4 w-4 shrink-0 text-skin-accent"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="opacity-75">{point}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-y divide-skin-line">
                {
                  [
                    ["OpenCart", `${plugin.minOC} or higher`],
                    ["Tested version", plugin.testedOC],
                    ["PHP", `${plugin.minPHP} or higher`],
                    ["Redis / Node.js", "Not required"],
                    ["Realtime transport", "HTTP batching + admin polling"],
                    ["Storage model", "Short-lived local JSON state"],
                  ].map(([label, value]) => (
                    <tr>
                      <td class="py-2.5 pr-4 font-medium opacity-70">
                        {label}
                      </td>
                      <td class="py-2.5 opacity-90">{value}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {
                [
                  "Download the packaged OpenCart zip and upload it through Extensions Installer.",
                  "In OpenCart admin, go to Extensions → Installer and upload the archive.",
                  "Go to Extensions → Extensions → Modules and install Realtime Mouse Tracker.",
                  "Open the module settings, enable tracking, and save your configuration.",
                  "Choose the storefront scope, sample rate, retention window, and polling interval that fit your store.",
                  "Open the module page in admin to watch the live dashboard update as shoppers browse matching routes.",
                ].map((step, i) => (
                  <li class="flex gap-3">
                    <span class="shrink-0 rounded border border-skin-line px-1.5 py-0.5 text-xs font-bold text-skin-accent tabular-nums">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="leading-snug opacity-75">{step}</span>
                  </li>
                ))
              }
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {
            [
              {
                q: "Does this require a separate realtime server?",
                a: "No. The extension runs inside OpenCart and uses browser batching, a collect endpoint, and an admin polling loop instead of Redis, Node.js, or WebSockets.",
              },
              {
                q: "Will storefront visitors see a widget or overlay?",
                a: "No. Shoppers only load the tracking script when the configured scope matches. The dashboard itself is admin-only.",
              },
              {
                q: "Can I demonstrate the dashboard without live traffic?",
                a: "Yes. Preview mode can simulate realistic scenarios so you can evaluate the interface, test behavior, or capture screenshots without depending on real visitors.",
              },
              {
                q: "Does it keep permanent analytics history?",
                a: "No. The design goal is live operational awareness, so the extension stores only a rolling snapshot in short-lived local state.",
              },
              {
                q: "Can I reduce the request load on busy stores?",
                a: "Yes. You can narrow the route scope, lower the sample rate, and adjust the retention and polling intervals to trade fidelity for lower runtime cost.",
              },
            ].map(item => (
              <details class="group rounded-lg border border-skin-line bg-skin-card shadow-sm">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                  <span>{item.q}</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </summary>
                <p class="border-t border-skin-line px-5 py-4 text-sm leading-relaxed opacity-70">
                  {item.a}
                </p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="border-t border-skin-line">
      <div class="mx-auto max-w-4xl px-4 py-14 text-center">
        <h2 class="mb-3 text-2xl font-bold">
          Need live operator visibility in OpenCart?
        </h2>
        <p class="mb-8 text-skin-base opacity-60">
          Lightweight packaging, native OpenCart integration, and no extra
          infrastructure to babysit.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href={plugin.marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-md bg-skin-accent px-6 py-3 text-sm font-semibold text-skin-inverted transition hover:brightness-110"
          >
            Open marketplace listing
          </a>
          <a
            href="/e-commerce-apps/opencart/"
            class="inline-flex items-center gap-2 rounded-md border border-skin-line bg-skin-card px-6 py-3 text-sm font-semibold transition hover:shadow-md"
          >
            ← Back to extension gallery
          </a>
        </div>
        <p class="mt-6 text-xs opacity-40">
          {plugin.license} &nbsp;·&nbsp; Developed by
          <a
            href={plugin.authorUrl}
            class="underline decoration-dashed underline-offset-2 hover:opacity-70"
            target="_blank"
            rel="noopener noreferrer"
          >
            Devlin Duldulao
          </a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
