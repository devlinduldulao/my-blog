---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

const plugin = {
  name: "Live Visitor Geo Pulse",
  slug: "live-visitor-geo-pulse",
  version: "1.0.0",
  testedOC: "4.1.0.3",
  minPHP: "8.3",
  minOC: "4.0",
  license: "MIT",
  githubUrl: "https://github.com/devlinduldulao/opencart_live_visitor_geo_pulse",
  marketplaceUrl: "https://www.opencart.com/index.php?route=marketplace/extension",
  authorUrl: "https://devlinduldulao.pro",
  tagline: "Privacy-first live visitor presence for OpenCart.",
  description:
    "A lightweight OpenCart 4 module that gives store owners a real-time dashboard of active visitors, country distribution, and device mix without storing IP addresses, adding custom database tables, or depending on Redis or a Node.js worker.",
};

const features = [
  {
    icon: "📈",
    title: "Live Admin Dashboard",
    desc: "Track active visitors, countries active, top country, and new visitors in the last minute directly from the OpenCart module settings page.",
  },
  {
    icon: "🌐",
    title: "Country Breakdown",
    desc: "Aggregate anonymous visitor presence by coarse country code so merchants can understand current geographic traffic at a glance.",
  },
  {
    icon: "📱",
    title: "Device Mix",
    desc: "See how current traffic is split across desktop, mobile, and tablet without attaching any personal identity to the visit.",
  },
  {
    icon: "🛡️",
    title: "Privacy-First Tracking",
    desc: "No raw IP storage, no persistent visitor history, and no customer profile creation. Only short-lived anonymous presence data is kept.",
  },
  {
    icon: "🧪",
    title: "Preview Traffic Mode",
    desc: "Generate sample visitors from the admin side so the dashboard can be demoed, reviewed, or screenshotted without needing real shoppers.",
  },
  {
    icon: "🧩",
    title: "OpenCart-Native Integration",
    desc: "Built with OpenCart MVC-L patterns and a Bootstrap 5 admin interface that feels consistent with the native OpenCart backend.",
  },
];

const steps = [
  { step: "01", title: "Visitor opens the storefront", desc: "An invisible frontend tracker is injected through the footer event flow, so there is no public analytics widget on the storefront." },
  { step: "02", title: "Heartbeat is sent", desc: "The browser posts a lightweight heartbeat on a configurable interval using an anonymous visitor token and device hint." },
  { step: "03", title: "Presence is summarized", desc: "The module resolves a coarse country code, updates short-lived presence storage, and refreshes aggregate counts without persisting personal data." },
  { step: "04", title: "Dashboard refreshes", desc: "The OpenCart admin dashboard polls the summary endpoint and re-renders the live cards, country table, and device mix in place." },
  { step: "05", title: "Stale visitors expire", desc: "When heartbeats stop, presence entries age out automatically from short-lived file storage, so the dashboard stays current without cron jobs." },
];

const privacyPoints = [
  "No IP addresses are stored in the module's runtime data.",
  "Only coarse country and device summaries are kept.",
  "Presence data is short-lived and automatically expires.",
  "No custom analytics tables are added to the OpenCart database.",
  "No Redis, Node.js worker, or third-party analytics service is required.",
  "Storefront shoppers do not see a public-facing widget or dashboard.",
];
---

<Layout title={`${plugin.name} — Real-Time Visitor Presence for OpenCart`}>
  <Header />
  <main id="main-content">
    <section class="border-skin-line border-b">
      <div class="mx-auto max-w-4xl px-4 py-16">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span class="bg-skin-accent text-skin-inverted rounded px-2 py-0.5 text-xs font-semibold">
            v{plugin.version}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            OpenCart {plugin.minOC}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            Tested {plugin.testedOC}
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            PHP {plugin.minPHP}+
          </span>
          <span class="border-skin-line rounded border px-2 py-0.5 text-xs opacity-70">
            {plugin.license}
          </span>
        </div>

        <h1 class="mb-4 text-4xl font-bold leading-tight">
          {plugin.name}
        </h1>
        <p class="text-skin-base mb-3 text-xl font-medium opacity-90">
          {plugin.tagline}
        </p>
        <p class="text-skin-base mb-8 max-w-2xl text-base leading-relaxed opacity-70">
          {plugin.description}
        </p>

        <div class="flex flex-wrap gap-3">
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-5 py-2.5 text-sm font-semibold transition hover:brightness-110"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/>
            </svg>
            View on GitHub
          </a>
          <a
            href={plugin.marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-5 py-2.5 text-sm font-semibold transition hover:shadow-md"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M4 4h16v2H4V4zm0 4h16v12H4V8zm4 3v2h8v-2H8zm0 4v2h5v-2H8z"/>
            </svg>
            OpenCart Marketplace
          </a>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-4xl px-4 py-14">
      <h2 class="mb-2 text-2xl font-bold">Features</h2>
      <p class="text-skin-base mb-8 opacity-60">Built for store owners who want live insight without analytics bloat.</p>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {features.map((feature) => (
          <div class="border-skin-line bg-skin-card rounded-lg border p-5 shadow-sm transition hover:shadow-md">
            <div class="mb-3 text-3xl">{feature.icon}</div>
            <h3 class="mb-1.5 text-base font-semibold">{feature.title}</h3>
            <p class="text-sm leading-relaxed opacity-65">{feature.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-2 text-2xl font-bold">How it works</h2>
        <p class="text-skin-base mb-10 opacity-60">From storefront heartbeat to native OpenCart admin dashboard in five steps.</p>
        <ol class="space-y-0">
          {steps.map((item, index) => (
            <li class="flex gap-6">
              <div class="flex flex-col items-center">
                <div class="bg-skin-accent text-skin-inverted flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-sm font-bold">
                  {item.step}
                </div>
                {index < steps.length - 1 && (
                  <div class="border-skin-line my-1 w-px grow border-l border-dashed" />
                )}
              </div>
              <div class="pb-8">
                <h3 class="mb-1 font-semibold">{item.title}</h3>
                <p class="text-sm leading-relaxed opacity-65">{item.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="border-skin-line bg-skin-card rounded-xl border p-8 shadow-sm">
          <div class="mb-1 text-3xl">🔐</div>
          <h2 class="mb-2 text-2xl font-bold">Privacy by design</h2>
          <p class="text-skin-base mb-6 opacity-60">
            The module is designed to keep tracking anonymous, short-lived, and operationally lightweight.
          </p>
          <ul class="space-y-3">
            {privacyPoints.map((point) => (
              <li class="flex items-start gap-3 text-sm leading-relaxed">
                <svg xmlns="http://www.w3.org/2000/svg" class="text-skin-accent mt-0.5 h-4 w-4 shrink-0" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="opacity-75">{point}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          <div>
            <h2 class="mb-4 text-xl font-bold">Requirements</h2>
            <table class="w-full text-sm">
              <tbody class="divide-skin-line divide-y">
                {[
                  ["OpenCart", `${plugin.minOC}+`],
                  ["Tested up to", plugin.testedOC],
                  ["PHP", `${plugin.minPHP}+`],
                  ["Storage", "Standard OpenCart file storage"],
                  ["Database", "No custom tables required"],
                  ["Extra services", "None"],
                ].map(([label, value]) => (
                  <tr>
                    <td class="py-2.5 pr-4 font-medium opacity-70">{label}</td>
                    <td class="py-2.5 opacity-90">{value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div>
            <h2 class="mb-4 text-xl font-bold">Installation</h2>
            <ol class="space-y-3 text-sm">
              {[
                "Download the .ocmod.zip package for the module.",
                "In OpenCart admin, go to Extensions -> Installer and upload the archive.",
                "Open Extensions -> Extensions and choose Modules from the extension type filter.",
                "Install Live Visitor Geo Pulse.",
                "Open the module settings page, enable the module, and save.",
                "Visit the dashboard panel and use preview traffic if you want to test the interface without live shoppers.",
              ].map((step, index) => (
                <li class="flex gap-3">
                  <span class="border-skin-line text-skin-accent shrink-0 rounded border px-1.5 py-0.5 text-xs font-bold tabular-nums">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <span class="leading-snug opacity-75">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14">
        <h2 class="mb-8 text-2xl font-bold">Frequently asked questions</h2>
        <div class="space-y-6">
          {[
            {
              q: "Does it show anything to storefront visitors?",
              a: "No. The storefront tracker is intentionally invisible. The value of the module lives in the OpenCart admin dashboard, not in any public visitor-facing widget.",
            },
            {
              q: "Does this module store IP addresses or customer history?",
              a: "No. The module tracks only short-lived anonymous presence data and coarse country or device summaries. It does not build persistent visitor histories.",
            },
            {
              q: "Do I need Redis, WebSockets, or a Node.js process?",
              a: "No. The module is designed to work with a standard OpenCart stack and short-lived file-backed runtime storage only.",
            },
            {
              q: "Can I demonstrate the dashboard before launch or on staging?",
              a: "Yes. Preview traffic mode injects sample visitors from the admin side so you can show the interface, take screenshots, or test the dashboard flow safely.",
            },
            {
              q: "How often does the visitor count update?",
              a: "The dashboard is heartbeat-based. Counts refresh on the configured interval, so the module stays light while still feeling close to real time.",
            },
          ].map((item) => (
            <details class="border-skin-line bg-skin-card group rounded-lg border shadow-sm">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold select-none">
                <span>{item.q}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 opacity-50 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </summary>
              <p class="border-skin-line border-t px-5 py-4 text-sm leading-relaxed opacity-70">
                {item.a}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="border-skin-line border-t">
      <div class="mx-auto max-w-4xl px-4 py-14 text-center">
        <h2 class="mb-3 text-2xl font-bold">Need live visitor insight without analytics overhead?</h2>
        <p class="text-skin-base mb-8 opacity-60">Built for OpenCart store owners who want immediate operational visibility and a native admin experience.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href={plugin.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-skin-accent text-skin-inverted inline-flex items-center gap-2 rounded-md px-6 py-3 text-sm font-semibold transition hover:brightness-110"
          >
            View Source on GitHub
          </a>
          <a
            href="/e-commerce-apps/opencart/"
            class="border-skin-line bg-skin-card inline-flex items-center gap-2 rounded-md border px-6 py-3 text-sm font-semibold transition hover:shadow-md"
          >
            ← Back to module gallery
          </a>
        </div>
        <p class="mt-6 text-xs opacity-40">
          {plugin.license} &nbsp;·&nbsp; Developed by
          <a href={plugin.authorUrl} class="underline decoration-dashed underline-offset-2 hover:opacity-70" target="_blank" rel="noopener noreferrer">
            Devlin Duldulao
          </a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>